{
  "manifest_version": 3,
  "name": "Apaga Sub V1.36",
  "description": "Ajuda a sair de newsletters usando o Gmail aberto no navegador.",
  "version": "1.36.0",
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Apaga Sub"
  },
  "permissions": [
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
